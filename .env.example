APP_NAME=Peep Club
APP_ENV=development
APP_DEBUG=false
PORT=3020
SESSION_SECRET=change-me-to-a-random-string

# Set OPERATOR_PIN to require PIN unlock (required on Railway; optional for trusted local use)
OPERATOR_PIN=

# Local: relative to project root. On Railway, leave unset — data uses the volume at /app/storage/data.json
DATA_PATH=storage/data.json
